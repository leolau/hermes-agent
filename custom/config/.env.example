# Email account passwords (Gmail App Passwords)
EMAIL1_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL2_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL3_PASSWORD=xxxx-xxxx-xxxx-xxxx

# DeepSeek API key for triage agent
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Telegram bot for escalations and merge confirmations
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ALLOWED_USERS=your-telegram-user-id
TELEGRAM_USER_ID=your-telegram-user-id

# Google Calendar OAuth2 (from Google Cloud Console)
GCAL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GCAL_CLIENT_SECRET=your-client-secret

# Google Calendar refresh tokens (from calendar_auth.py flow)
GCAL_REFRESH_TOKEN_1=your-refresh-token-for-account-1
GCAL_REFRESH_TOKEN_2=your-refresh-token-for-account-2
GCAL_REFRESH_TOKEN_3=your-refresh-token-for-account-3
