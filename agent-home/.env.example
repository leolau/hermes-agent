# agent-home environment (FG-20 Wave A).
#
# Policy (AGENTS.md + FG-20): NO new non-secret HERMES_* env vars. Real secrets
# live here in .env (like a Supabase key); deploy-topology values are namespaced
# AGENT_HOME_* so they never extend the Python HERMES_* namespace. Copy this to
# `agent-home/.env.local` for local dev; never commit real values.

# --- Secrets -----------------------------------------------------------------
# HMAC key that signs the agent-home session cookie. Generate a long random
# value, e.g.  openssl rand -hex 32
AGENT_HOME_SESSION_SECRET=

# Postgres DSN for server-side Supabase reads. Same connection string the
# Python backend uses for the Supabase app datastore (drives FORCE'd RLS).
DATABASE_URL=

# Supabase project URL + anon (browser-safe) key, for RLS-scoped Realtime.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Deploy topology (non-secret) --------------------------------------------
# Base URL of the Python AI layer (/api/*, /auth/*). On the prod box this is the
# on-box loopback that Caddy also fronts. Defaults to http://127.0.0.1:9119.
AGENT_HOME_API_URL=http://127.0.0.1:9119

# C3 datastore mode: dev -> app_dev schema, prod -> app_prod. Defaults to dev.
AGENT_HOME_DATASTORE_MODE=dev
